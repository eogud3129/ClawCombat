#version 460

// Multi-range Q1_0 matvec **fused with the preceding RMS-norm + scale**:
// one dispatch produces output rows for 2 or 3 separate weight tensors that
// share the same K dimension and the same input activation. Used for the
// matvec single-token (tg) path's fused QKV (3 ranges) and gate+up (2 ranges).
//
// Vulkan: Stage 1 stages `x*w_norm` to f16 LDS while accumulating ssq;
// Stage 2 quantizes the staged values to Q8_0 (no inv_rms fold here — applied
// once at row-write); Stage 3 runs `dotPacked4x8EXT` matvec.
//
// Metal: Apple lacks DP4a (see `memory/apple_gpu_no_dp4a.md`). Stage 2's
// Q8_0 quantize is skipped entirely; the inner loop is sign-flip-and-
// accumulate against the f16 staged x*w_norm directly. inv_rms is folded
// once at row-write on both backends.
//
// Apple sweep: WG_Y=32 (256 threads, 8 simdgroups per WG) over WG_Y=16 wins
// ~5% on e2e_tg via better amortization of the K_V4-sized `q1_x_sh` load and
// the halved dispatch count. The cross-SG ssq merge cost (8 SGs vs 4) is
// real but dominated by the bandwidth win. Smaller WG (WG_Y∈{4,8}) regresses
// sharply.

layout(constant_id = 0) const uint SUBGROUP_SIZE = 32;
// `K_V4` = n_embd / 4, baked at load time per model so the LDS arrays fit
// the actual row exactly. SpecConstant array sizes are evaluated post-
// specialization so q1_x_sh / q1_a_qs_sh land at the per-model size.
layout(constant_id = 2) const uint K_V4 = 640;

layout(push_constant) uniform Params {
    uint k;
    uint n_total;
    uint input_offset;
    uint dispatch_x_dim;
    uint w_norm_off;
    float eps;
    uint d_offset_0;
    uint qs_offset_0;
    uint n_0;
    uint output_offset_0;
    uint d_offset_1;
    uint qs_offset_1;
    uint n_1;
    uint output_offset_1;
    uint d_offset_2;
    uint qs_offset_2;
    uint n_2;
    uint output_offset_2;
}
p;

layout(set = 0, binding = 0, std430) readonly buffer WBuf { uint weights[]; };
layout(set = 0, binding = 1, std430) buffer ActBuf { float16_t act[]; };
layout(set = 0, binding = 2, std430) readonly buffer NormBuf { float16_t w_norms[]; };

#include "lib/bitfield.glsl"
#include "lib/q1_0_load.glsl"

const uint WG_X = 8u;
#ifndef METAL_BACKEND
const uint WG_Y = 16u;
#else
const uint WG_Y = 32u;
#endif
const uint WG = WG_X * WG_Y;
const uint ROWS_PER_WG = WG_Y;

const uint NUM_SUBGROUPS = (WG + SUBGROUP_SIZE - 1u) / SUBGROUP_SIZE;

shared f16vec4 q1_x_sh[K_V4];
#ifndef METAL_BACKEND
// Q1_NB_Q8 = K / 32 = (K_V4 * 4) / 32 = K_V4 / 8.
// Declared as a variable so q1_0_matvec.glsl can reference it (the value
// is spec-constant-derived and thus not a compile-time constant here).
uint Q1_NB_Q8;
shared uint q1_a_qs_sh[K_V4]; // K bytes packed as u32 (= K_V4 u32 slots)
shared float q1_a_d_sh[(K_V4 << 2u) / 32u];
#endif
shared float sg_partial[NUM_SUBGROUPS];

#include "lib/q1_0_matvec.glsl"
#include "lib/subgroup_reduce_scalar.glsl"

#ifndef METAL_BACKEND
layout(local_size_x = 128, local_size_y = 1, local_size_z = 1) in;
#else
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;
#endif

void main() {
    uint K = K_V4 << 2u;
#ifndef METAL_BACKEND
    uint NB_Q8 = K >> 5u;
    Q1_NB_Q8 = NB_Q8;
#endif
    uint wg_idx = gl_WorkGroupID.y * p.dispatch_x_dim + gl_WorkGroupID.x;
    uint tid = gl_LocalInvocationIndex;
    uint ty = tid >> 3u; // / WG_X
    uint tx = tid & (WG_X - 1u);
    uint global_row = wg_idx * ROWS_PER_WG + ty;
    bool valid = global_row < p.n_total;
    uint nb_q1 = K >> 7u;

    // ---- Stage 1: load x and w_norm; stage `x * w_norm` into q1_x_sh; accumulate ssq.
    uint in_v4_off = p.input_offset >> 2u;
    uint w_v4_off = p.w_norm_off >> 2u;
    vec4 ssq = vec4(0.0);
    for (uint v = tid; v < K_V4; v += WG) {
        uint base = (in_v4_off + v) << 2u;
        f16vec4 xv4 = f16vec4(act[base + 0u], act[base + 1u], act[base + 2u], act[base + 3u]);
        vec4 xv4f = vec4(xv4);
        ssq += xv4f * xv4f;
        uint w_base = (w_v4_off + v) << 2u;
        f16vec4 wv4 = f16vec4(w_norms[w_base + 0u], w_norms[w_base + 1u], w_norms[w_base + 2u], w_norms[w_base + 3u]);
        q1_x_sh[v] = xv4 * wv4;
    }

    float inv_rms = inversesqrt(wg_sum(reduce_add(ssq)) / float(K) + p.eps);

#ifndef METAL_BACKEND
    // ---- Stage 2: quantize each Q8_0 block (8 f16vec4) to Q8_0 ----
    if (tid < NB_Q8) {
        uint block_v4_base = tid * 8u;
        float16_t max_abs_h = float16_t(0.0);
        [[unroll]] for (uint i = 0u; i < 8u; i += 1u) {
            f16vec4 af = abs(q1_x_sh[block_v4_base + i]);
            max_abs_h = max(max_abs_h, max(max(af.x, af.y), max(af.z, af.w)));
        }
        float max_abs = float(max_abs_h);
        // Don't fold inv_rms here — apply it once at row-write below.
        q1_a_d_sh[tid] = max_abs / 127.0;
        [[unroll]] for (uint i = 0u; i < 8u; i += 1u) {
            q1_a_qs_sh[i * NB_Q8 + tid] = packSnorm4x8(vec4(q1_x_sh[block_v4_base + i]) / max(max_abs, 1e-30));
        }
    }
    barrier();
#endif

    if (!valid)
        return;

    // ---- Stage 3: matvec inner loop ----
    uint d_off = 0u;
    uint qs_off = 0u;
    uint out_off = 0u;
    uint local_row = 0u;
    if (global_row < p.n_0) {
        d_off = p.d_offset_0;
        qs_off = p.qs_offset_0;
        out_off = p.output_offset_0;
        local_row = global_row;
    } else if (global_row < p.n_0 + p.n_1) {
        d_off = p.d_offset_1;
        qs_off = p.qs_offset_1;
        out_off = p.output_offset_1;
        local_row = global_row - p.n_0;
    } else {
        d_off = p.d_offset_2;
        qs_off = p.qs_offset_2;
        out_off = p.output_offset_2;
        local_row = global_row - p.n_0 - p.n_1;
    }

    uint row_d_byte = d_off + local_row * nb_q1 * D_FP16_PER_BLOCK * 2u;
    uint row_qs_byte = qs_off + local_row * nb_q1 * QS_BYTES_PER_BLOCK;

    float acc = 0.0;
    for (uint b = tx; b < nb_q1; b += WG_X) {
        uint d_byte = row_d_byte + b * D_FP16_PER_BLOCK * 2u;
        uint qs_word_base = (row_qs_byte + b * QS_BYTES_PER_BLOCK) >> 2u;
        acc += q1_0_block_dot(qs_word_base, b, d_byte);
    }

    acc += subgroupShuffleXor(acc, 1u);
    acc += subgroupShuffleXor(acc, 2u);
    acc += subgroupShuffleXor(acc, 4u);
    if (tx == 0u) {
        uint yi = out_off + local_row;
        act[yi] = float16_t(acc * inv_rms); // fused matvecs don't accumulate
    }
}
