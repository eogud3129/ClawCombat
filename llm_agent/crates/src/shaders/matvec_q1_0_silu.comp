#version 460

// Q1_0 matvec with SiLU(gate) * up activation fold.
//
// Vulkan: in-LDS Q8_0 quantize of `silu(g)*u`, then `dotPacked4x8EXT` matvec.
//
// Metal: f16-staged `silu(g)*u` (no Q8_0 round-trip), then sign-flip-and-
// accumulate inner loop on Apple's f16 ALU pipe (no DP4a; see
// `memory/apple_gpu_no_dp4a.md`).
//
// See `matvec_q1_0.comp` for the tile/shuffle layout — only the per-block
// loader differs (computes `silu(g) * u` on the fly instead of just loading
// `act`). Apple sweep also picks WG_Y=32 (256 threads, 8 simdgroups per WG)
// over WG_Y=16: ~5% on e2e_tg via better amortization of the per-WG `q1_x_sh`
// activation load (5 KB) over more output rows; halves dispatch count.

layout(push_constant) uniform Params {
    uint k;
    uint n;
    uint d_offset;
    uint qs_offset;
    uint gate_offset;
    uint up_offset;
    uint output_offset;
    uint accumulate;
    uint dispatch_x_dim;
}
p;

layout(set = 0, binding = 0, std430) readonly buffer WBuf { uint weights[]; };
layout(set = 0, binding = 1, std430) buffer ActBuf { float16_t act[]; };

#include "lib/bitfield.glsl"
#include "lib/q1_0_load.glsl"

const uint WG_X = 8u;
#ifndef METAL_BACKEND
const uint WG_Y = 16u;
#else
const uint WG_Y = 32u;
#endif
const uint WG = WG_X * WG_Y;
const uint ROWS_PER_WG = WG_Y;
const uint TILE_K = 4096u;
#ifndef METAL_BACKEND
const uint Q1_NB_Q8 = TILE_K / 32u;
const uint TILE_QS_LEN = TILE_K >> 2u;

shared uint q1_a_qs_sh[TILE_QS_LEN];
shared float q1_a_d_sh[Q1_NB_Q8];
#else
const uint TILE_K_V4 = TILE_K >> 2u;

shared f16vec4 q1_x_sh[TILE_K_V4];
#endif

#include "lib/q1_0_matvec.glsl"

#ifndef METAL_BACKEND
layout(local_size_x = 8, local_size_y = 16, local_size_z = 1) in;
#else
layout(local_size_x = 8, local_size_y = 32, local_size_z = 1) in;
#endif

void main() {
    uint wg_idx = gl_WorkGroupID.y * p.dispatch_x_dim + gl_WorkGroupID.x;
    uint row = wg_idx * ROWS_PER_WG + gl_LocalInvocationID.y;
    uint tx = gl_LocalInvocationID.x;
    uint ty = gl_LocalInvocationID.y;
    uint tid = ty * WG_X + tx;
    bool valid = row < p.n;
    uint nb_q1 = p.k >> 7u;

    uint row_d_byte = p.d_offset + row * nb_q1 * D_FP16_PER_BLOCK * 2u;
    uint row_qs_byte = p.qs_offset + row * nb_q1 * QS_BYTES_PER_BLOCK;

    float acc = 0.0;

    for (uint tile_start = 0u; tile_start < p.k; tile_start += TILE_K) {
        uint tile_size = min(TILE_K, p.k - tile_start);
        uint nb_q1_tile = tile_size >> 7u;

#ifndef METAL_BACKEND
        // ---- Vulkan: in-LDS Q8_0 quantize of silu(g)*u per Q8_0 block ----
        uint nb_q8_tile = tile_size >> 5u;
        if (tid < nb_q8_tile) {
            uint elem_base = tile_start + tid * 32u;
            uint g_v4_off = (p.gate_offset + elem_base) >> 2u;
            uint u_v4_off = (p.up_offset + elem_base) >> 2u;

            f16vec4 v[8];
            float16_t max_abs_h = float16_t(0.0);
            [[unroll]] for (uint i = 0u; i < 8u; i += 1u) {
                uint gb = (g_v4_off + i) << 2u;
                uint ub = (u_v4_off + i) << 2u;
                vec4 g = vec4(f16vec4(act[gb], act[gb + 1u], act[gb + 2u], act[gb + 3u]));
                f16vec4 u = f16vec4(act[ub], act[ub + 1u], act[ub + 2u], act[ub + 3u]);
                vec4 s = g / (vec4(1.0) + exp(-g));
                v[i] = f16vec4(s) * u;
                f16vec4 af = abs(v[i]);
                max_abs_h = max(max_abs_h, max(max(af.x, af.y), max(af.z, af.w)));
            }

            float max_abs = float(max_abs_h);
            q1_a_d_sh[tid] = max_abs / 127.0;
            [[unroll]] for (uint i = 0u; i < 8u; i += 1u) {
                q1_a_qs_sh[i * Q1_NB_Q8 + tid] = packSnorm4x8(vec4(v[i]) / max(max_abs, 1e-30));
            }
        }
#else
        // ---- Metal: f16 staging of silu(g)*u (no Q8_0 round-trip) ----
        uint tile_v4 = tile_size >> 2u;
        uint g_v4_off = (p.gate_offset + tile_start) >> 2u;
        uint u_v4_off = (p.up_offset + tile_start) >> 2u;
        for (uint v = tid; v < tile_v4; v += WG) {
            uint gb = (g_v4_off + v) << 2u;
            uint ub = (u_v4_off + v) << 2u;
            vec4 g = vec4(f16vec4(act[gb], act[gb + 1u], act[gb + 2u], act[gb + 3u]));
            f16vec4 u = f16vec4(act[ub], act[ub + 1u], act[ub + 2u], act[ub + 3u]);
            vec4 sf = g / (vec4(1.0) + exp(-g));
            q1_x_sh[v] = f16vec4(sf) * u;
        }
#endif
        barrier();

        if (valid) {
            uint b_q1_base_global = tile_start >> 7u;
            for (uint b_local = tx; b_local < nb_q1_tile; b_local += WG_X) {
                uint b = b_q1_base_global + b_local;
                uint d_byte = row_d_byte + b * D_FP16_PER_BLOCK * 2u;
                uint qs_word_base = (row_qs_byte + b * QS_BYTES_PER_BLOCK) >> 2u;
                acc += q1_0_block_dot(qs_word_base, b_local, d_byte);
            }
        }
        barrier();
    }

    if (!valid)
        return;

    acc += subgroupShuffleXor(acc, 1u);
    acc += subgroupShuffleXor(acc, 2u);
    acc += subgroupShuffleXor(acc, 4u);
    if (tx == 0u) {
        uint yi = p.output_offset + row;
        act[yi] = float16_t(p.accumulate != 0u ? float(act[yi]) + acc : acc);
    }
}
