#version 460

// Fused per-layer K-side pre-KV pipeline:
//   rms_norm(K head) -> *w_k_norm -> NEOX-RoPE -> Q8_0 quantize -> write kv_k.
// V-side runs in the same workgroup: Q8_0 quantize + write kv_v (no rms, no
// rope). Replaces a 3-dispatch sequence (rms_norm K, rope K, kv_writeback)
// with 1.
//
// Threading: WG=32, one thread per **vec4** of head_dim (head_dim=128 = 32*4).
// Each thread holds 4 contiguous head_dim positions [t*4 .. t*4+3] for both K
// and V, so:
//   - the per-32-element Q8_0 block (block b = positions [b*32..b*32+31]) is
//     covered by 8 contiguous threads, each owning 4 elements within the
//     block. Per-block max-abs is a 4-elementwise + 8-lane subgroup butterfly
//     (in-subgroup since subgroup_min_size >= 8). The 4-byte pack is
//     `packSnorm4x8` — no cross-lane gather, no `qv_sh` smem.
//   - NEOX RoPE pairs position i with i+64. With contiguous-per-thread
//     layout, the partner of every element in thread t lives in thread t^16
//     at the SAME vec4 component, so the partner load is one shmem read of a
//     vec4 (no per-element pair lookup, no half-boundary thread split).
//
// Dispatch (n_kv_head, m_tokens, 1).

layout(constant_id = 0) const uint SUBGROUP_SIZE = 32;

layout(push_constant) uniform Params {
    uint k_cur_off;          // f16 element offset of K_cur in act
    uint v_cur_off;          // f16 element offset of V_cur in act
    uint w_k_norm_off;       // f16 element offset of w_k_norm[0..head_dim] in w_norms
    uint rope_offset;        // f16 element base offset into rope_cs (typically 0)
    uint dst_d_word_offset;  // u32-word offset into kv_{k,v} d-section, layer base
    uint dst_qs_byte_offset; // byte offset into kv_{k,v} qs-section, layer base
    uint pos_base;           // first absolute cache position to write into
    uint kv_dim;             // = n_kv_head * head_dim
    uint nb_per_row;         // = kv_dim / 32
    float eps;
}
p;

layout(set = 0, binding = 0, std430) readonly buffer ActBuf { f16vec4 act[]; };
layout(set = 0, binding = 1, std430) readonly buffer WBuf { f16vec4 w_norms[]; };
layout(set = 0, binding = 2, std430) readonly buffer RopeBuf { f16vec2 rope_cs[]; };
layout(set = 0, binding = 3, std430) buffer KBuf { uint kv_k[]; };
layout(set = 0, binding = 4, std430) buffer VBuf { uint kv_v[]; };

const uint HEAD_DIM = 128u;
const uint HALF_DIM = 64u;
const uint NB_PER_HEAD = HEAD_DIM / 32u;
const uint WG = 32u;
const uint ELEMS_PER_THREAD = 4u;
const uint LANES_PER_BLOCK = 32u / ELEMS_PER_THREAD; // 8 threads per Q8_0 block
const uint NUM_SUBGROUPS = (WG + SUBGROUP_SIZE - 1u) / SUBGROUP_SIZE;

// rope_in_sh holds normed-and-weighted K so RoPE can fetch the pair partner
// across the head-half boundary. Stored as f16vec4 with the same
// thread-contiguous layout as the per-thread state (thread t -> slot t).
shared f16vec4 rope_in_sh[WG];
shared float sg_partial[NUM_SUBGROUPS];

#include "lib/subgroup_reduce_scalar.glsl"

layout(local_size_x = 32, local_size_y = 1, local_size_z = 1) in;

void main() {
    uint head = gl_WorkGroupID.x;
    uint tok = gl_WorkGroupID.y;
    uint tid = gl_LocalInvocationID.x;

    uint kv_token_off = tok * p.kv_dim + head * HEAD_DIM;
    uint base_pos = tid * ELEMS_PER_THREAD; // 0..124, head_dim element offset
    uint k_load = (p.k_cur_off + kv_token_off + base_pos) >> 2u;
    uint v_load = (p.v_cur_off + kv_token_off + base_pos) >> 2u;
    uint w_load = (p.w_k_norm_off + base_pos) >> 2u;

    // ---- Load K, V, w_k_norm as vec4 ----
    vec4 k_raw = vec4(act[k_load]);
    vec4 v_raw = vec4(act[v_load]);
    f16vec4 wkn = w_norms[w_load];

    // ---- RMS sum-of-squares over the K head (128 elements) ----
    float inv_h = inversesqrt(wg_sum(dot(k_raw, k_raw)) / float(HEAD_DIM) + p.eps);

    // ---- normalize * w_k_norm, stash for the RoPE partner load ----
    f16vec4 k_normed = f16vec4(k_raw * inv_h) * wkn;
    rope_in_sh[tid] = k_normed;
    barrier();

    // ---- NEOX RoPE in-register ----
    // Pair partner of position p (p<64) is p+64, lives in thread t^16 at the
    // same vec4 component. Both halves of the thread's vec4 are in the same
    // RoPE half (lower or upper), since 4 | 64.
    f16vec4 partner = rope_in_sh[tid ^ 16u];
    uint j_base = base_pos & ~HALF_DIM;
    uint cs_base = (p.rope_offset + (p.pos_base + tok) * HEAD_DIM) >> 1u;

    vec4 k_post;
    [[unroll]] for (uint e = 0u; e < ELEMS_PER_THREAD; e += 1u) {
        uint j = j_base + e;
        vec2 cs = rope_cs[cs_base + j];
        float a = float(k_normed[e]);
        float b = float(partner[e]);
        b = uintBitsToFloat((base_pos - HALF_DIM) & 0x80000000u ^ floatBitsToUint(b));
        // is_lower:  a*c - b*s   (a is lower, b is upper partner)
        // upper:     a*c + b*s   (a is upper, b is lower partner)
        k_post[e] = dot(vec2(a, b), cs);
    }

    // ---- Per-32-block max-abs for K and V (8-lane subgroup butterfly) ----
    // 8 threads contribute 4 elements each per block; masks {1,2,4} stay
    // in-subgroup (subgroup_min_size >= 8 enforced at load time).
    vec4 akv4 = abs(k_post);
    vec4 avv4 = abs(v_raw);
    float ak = max(max(akv4.x, akv4.y), max(akv4.z, akv4.w));
    float av = max(max(avv4.x, avv4.y), max(avv4.z, avv4.w));
    ak = max(ak, subgroupShuffleXor(ak, 1u));
    av = max(av, subgroupShuffleXor(av, 1u));
    ak = max(ak, subgroupShuffleXor(ak, 2u));
    av = max(av, subgroupShuffleXor(av, 2u));
    ak = max(ak, subgroupShuffleXor(ak, 4u));
    av = max(av, subgroupShuffleXor(av, 4u));

    uint pk = packSnorm4x8(k_post / max(ak, 1e-30));
    uint pv = packSnorm4x8(v_raw / max(av, 1e-30));

    uint pos_abs = p.pos_base + tok;
    uint block_in_head = tid >> 3u;                             // 0..3; / LANES_PER_BLOCK
    uint lane_in_block = tid - block_in_head * LANES_PER_BLOCK; // 0..7

    // qs write: one u32 per thread, no cross-lane gather.
    uint qs_byte_in_layer = p.dst_qs_byte_offset + pos_abs * p.kv_dim + head * HEAD_DIM + tid * 4u;
    kv_k[qs_byte_in_layer >> 2u] = pk;
    kv_v[qs_byte_in_layer >> 2u] = pv;

    // d (FP32 scale) — one writer per block.
    if (lane_in_block == 0u) {
        uint block_global = pos_abs * p.nb_per_row + head * NB_PER_HEAD + block_in_head;
        kv_k[p.dst_d_word_offset + block_global] = floatBitsToUint(ak / 127.0);
        kv_v[p.dst_d_word_offset + block_global] = floatBitsToUint(av / 127.0);
    }
}
