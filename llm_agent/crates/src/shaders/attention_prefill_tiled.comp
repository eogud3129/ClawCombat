#version 460

// Q-tiled + GQA-batched FlashAttention-2 prefill kernel.
//
// dispatch: (n_kv_head, ceil(M / Q_TILE), 1)
//
// Each workgroup handles Q_TILE consecutive query tokens × Q_PER_GROUP=4 Q
// heads sharing the same KV head. K and V are loaded ONCE per cache position
// and reused across all Q_TILE * Q_PER_GROUP queries within the workgroup.
//
// WG = 32 with ELEMS_PER_THREAD = 4 covers head_dim=128. On hardware with
// `subgroup_size >= 32` (wave32, wave64, Apple, Intel Gen12+) the workgroup
// is exactly one subgroup and `wg_sum_v4` early-returns to a single
// `subgroupAdd` — no cross-subgroup combine, no `barrier()` in the inner
// loop. On hardware with smaller subgroups (e.g. Intel Gen11, Mali) WG=32
// spans multiple subgroups and `wg_sum_v4` falls back to a smem-staged
// merge for the per-`t` dot reduction. The previous WG=64/EPT=2 layout had
// the merge fire on wave32 too (two `barrier()`s per cache position),
// which dominated pp prefill time on wave32 hardware.
//
// Q_TILE is fixed at 2 and the per-query state (Q registers, output
// accumulators, online-softmax m/l) is held in small arrays indexed
// inside `[[unroll]]` for-loops. The unroll attribute causes the
// SPIR-V loop unroller (run by `spirv-opt -O` in build.rs) to rewrite
// every array index as a constant before the driver compiler sees it,
// so the arrays stay in registers — equivalent to manual unrolling.
//
// **Output is Q8_0 written directly to `outbuf` (act_q8)**: the Wo matmul
// reads it as Q8_0 input. Per-block max-abs uses a `subgroupShuffleXor`
// butterfly with masks {1, 2, 4} that always stay in-subgroup (subgroup_min
// >= 8 enforced at load time); masks 8/16 are gated on the larger of the
// baked min size and the runtime subgroup size, with a smem-staged stitch
// across SG-clusters when no cluster covers a full 32-block (the pattern
// used in kv_writeback_fused). The 4-byte pack uses `subgroupShuffle` over
// 4-lane clusters, which always sits inside one subgroup.
//
// Invariants (asserted by the host):
//   - head_dim == ELEMS_PER_THREAD * WG  (head_dim=128, WG=32, EPT=4)
//   - n_head == n_kv_head * Q_PER_GROUP   (Q_PER_GROUP=4 for Bonsai 4B/8B)
//   - subgroup_size >= 8                  (matvec butterfly + pack4 cluster)

layout(constant_id = 0) const uint SUBGROUP_SIZE = 32;

layout(push_constant) uniform Params {
    uint head_dim;
    uint n_head;
    uint n_kv_head;
    uint m_tokens;
    uint pos_base;
    uint kv_stride;
    uint q_offset; // f16 element offset of Q in `act`
    uint k_d_word_offset;
    uint k_qs_byte_offset;
    uint v_d_word_offset;
    uint v_qs_byte_offset;
    uint out_d_offset;  // byte offset of Q8_0 d-section in `act_q8`
    uint out_qs_offset; // byte offset of Q8_0 qs-section in `act_q8`
    float scale;
}
p;

layout(set = 0, binding = 0, std430) readonly buffer ActBuf { float16_t act[]; };
layout(set = 0, binding = 1, std430) readonly buffer KCache { uint k_cache[]; };
layout(set = 0, binding = 2, std430) readonly buffer VCache { uint v_cache[]; };
layout(set = 0, binding = 3, std430) buffer OutBuf { uint outbuf[]; };

const uint WG = 32u;
const uint NUM_SUBGROUPS = (WG + SUBGROUP_SIZE - 1u) / SUBGROUP_SIZE;
const uint Q_PER_GROUP = 4u;
const uint ELEMS_PER_THREAD = 4u;
const uint Q_TILE = 2u;
const float NEG_INF = -1.0e30;

shared vec4 sg_partial4[NUM_SUBGROUPS];
// Cluster-stitch buffer for block_max_abs on subgroups smaller than WG=32.
// Kept separate from sg_partial4 so the t-loop's last wg_sum_v4 cannot race
// with the first write_block call.
shared float sg_partial_amax[NUM_SUBGROUPS];

#include "lib/bitfield.glsl"
#include "lib/kv_cache_load.glsl"
#include "lib/q8_0_quantize.glsl"
#include "lib/subgroup_reduce_v4.glsl"

void write_block(float v, uint block_global) {
    // WG=32, so lane-in-block is exactly the local invocation id (0..31).
    uint lane_in_block = gl_LocalInvocationID.x;
    float max_abs = block_max_abs(v);
    float id_inv = 127.0 / max(max_abs, 1e-30);
    uint qv = extract_bits(uint(int(clamp(round(v * id_inv), -127.0, 127.0))), 0u, 8u);
    uint packed = pack4(qv);
    if ((lane_in_block & 3u) == 0u) {
        uint qs_byte = p.out_qs_offset + block_global * 32u + lane_in_block;
        outbuf[qs_byte >> 2u] = packed;
    }
    if (lane_in_block == 0u) {
        outbuf[(p.out_d_offset >> 2u) + block_global] = floatBitsToUint(max_abs / 127.0);
    }
}

layout(local_size_x = 32, local_size_y = 1, local_size_z = 1) in;

void main() {
    uint g = gl_WorkGroupID.x;
    uint m_tile = gl_WorkGroupID.y;
    if (g >= p.n_kv_head)
        return;
    uint m_base = m_tile * Q_TILE;
    if (m_base >= p.m_tokens)
        return;
    uint tid = gl_LocalInvocationID.x;
    uint hd = p.head_dim;
    uint q_stride = p.n_head * hd;
    uint g_off = g * hd;
    uvec2 m_idx = m_base + uvec2(0u, 1u);
    bvec2 ml_valid = bvec2(true, m_idx.y < p.m_tokens);
    uvec2 q_base = m_idx * q_stride + p.q_offset + g * Q_PER_GROUP * hd;
    uint t_max = p.pos_base + m_idx.y + uint(ml_valid.y);

    uint d_lane[ELEMS_PER_THREAD];
    [[unroll]] for (uint e = 0u; e < ELEMS_PER_THREAD; e += 1u) { d_lane[e] = tid + e * WG; }

    // Per-thread Q registers, online-softmax (m/l) state, and output accumulators.
    // [[unroll]] on every loop indexed into these arrays makes the indices
    // compile-time constants in SPIR-V, so the arrays stay in registers.
    float q[Q_TILE][Q_PER_GROUP][ELEMS_PER_THREAD];
    [[unroll]] for (uint ml = 0u; ml < Q_TILE; ml += 1u) {
        [[unroll]] for (uint pg = 0u; pg < Q_PER_GROUP; pg += 1u) {
            [[unroll]] for (uint e = 0u; e < ELEMS_PER_THREAD; e += 1u) {
                q[ml][pg][e] = float(act[q_base[ml] + pg * hd + d_lane[e]]);
            }
        }
    }

    vec4 m_run[Q_TILE];
    vec4 l_run[Q_TILE];
    [[unroll]] for (uint ml = 0u; ml < Q_TILE; ml += 1u) {
        m_run[ml] = vec4(NEG_INF);
        l_run[ml] = vec4(0.0);
    }

    float o[Q_TILE][Q_PER_GROUP][ELEMS_PER_THREAD];
    [[unroll]] for (uint ml = 0u; ml < Q_TILE; ml += 1u) {
        [[unroll]] for (uint pg = 0u; pg < Q_PER_GROUP; pg += 1u) {
            [[unroll]] for (uint e = 0u; e < ELEMS_PER_THREAD; e += 1u) { o[ml][pg][e] = 0.0; }
        }
    }

    for (uint t = 0u; t < t_max; t += 1u) {
        float k_e[ELEMS_PER_THREAD];
        [[unroll]] for (uint e = 0u; e < ELEMS_PER_THREAD; e += 1u) { k_e[e] = load_k(t, g_off + d_lane[e]); }

        vec4 corr[Q_TILE];
        vec4 w_attn[Q_TILE];
        [[unroll]] for (uint ml = 0u; ml < Q_TILE; ml += 1u) {
            vec4 local_dots;
            [[unroll]] for (uint pg = 0u; pg < Q_PER_GROUP; pg += 1u) {
                float d_acc = 0.0;
                [[unroll]] for (uint e = 0u; e < ELEMS_PER_THREAD; e += 1u) { d_acc += q[ml][pg][e] * k_e[e]; }
                local_dots[pg] = d_acc;
            }
            // wg_sum_v4 early-returns to a single subgroupAdd when the WG fits
            // in one subgroup (SG_size >= 32, the common case). Falls back to
            // an smem-staged combine on hardware with smaller subgroups.
            vec4 dots = wg_sum_v4(local_dots);
            bool causal_ok = ml_valid[ml] && (t <= p.pos_base + m_idx[ml]);
            vec4 scores = causal_ok ? (dots * p.scale) : vec4(NEG_INF);
            vec4 m_new = max(m_run[ml], scores);
            corr[ml] = exp(m_run[ml] - m_new);
            w_attn[ml] = exp(scores - m_new);
            l_run[ml] = l_run[ml] * corr[ml] + w_attn[ml];
            m_run[ml] = m_new;
        }

        float v_e[ELEMS_PER_THREAD];
        [[unroll]] for (uint e = 0u; e < ELEMS_PER_THREAD; e += 1u) { v_e[e] = load_v(t, g_off + d_lane[e]); }

        [[unroll]] for (uint ml = 0u; ml < Q_TILE; ml += 1u) {
            [[unroll]] for (uint pg = 0u; pg < Q_PER_GROUP; pg += 1u) {
                [[unroll]] for (uint e = 0u; e < ELEMS_PER_THREAD; e += 1u) {
                    o[ml][pg][e] = o[ml][pg][e] * corr[ml][pg] + w_attn[ml][pg] * v_e[e];
                }
            }
        }
    }

    // ---- Normalize and write Q8_0 directly to outbuf ----
    // head_dim=128 packs into 4 Q8_0 blocks (32 elems each). With WG=32, every
    // thread contributes one element per (pg, e); e selects the block within
    // the pg's slice of head_dim, no half_id needed.
    uint nb_per_token = (p.n_head * hd) >> 5u; // = q_dim / 32 = 128

    [[unroll]] for (uint ml = 0u; ml < Q_TILE; ml += 1u) {
        if (!ml_valid[ml])
            continue;
        vec4 inv = 1.0 / l_run[ml];
        uint block_base = m_idx[ml] * nb_per_token + g * Q_PER_GROUP * 4u;
        [[unroll]] for (uint pg = 0u; pg < Q_PER_GROUP; pg += 1u) {
            [[unroll]] for (uint e = 0u; e < ELEMS_PER_THREAD; e += 1u) {
                write_block(o[ml][pg][e] * inv[pg], block_base + pg * 4u + e);
            }
        }
    }
}
