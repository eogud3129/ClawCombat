#version 460

// Fused: y = rms_norm(x) * w  →  Q8_0 quantize  →  write to act_q8.
//
// Replaces the prefill-path pair `rms_norm` (writes act.x_norm) +
// `quantize_q8_0` (reads act.x_norm, writes act_q8). The fused version keeps
// the normalized values in registers and never touches act.x_norm.
//
// Output layout (matches `quantize_q8_0`):
//   d (f32):  outbuf[d_offset/4 + token*nb_q8 + b]
//   qs (i8):  outbuf[qs_offset/4 + (token*k + b*32)/4 + sub] for sub in 0..8
//
// dispatch: (m, 1, 1) — one workgroup per token.
//
// Threading: WG=64, one thread per **vec4** of input. Per iteration we cover
// 256 elements = 8 Q8_0 blocks; 8 threads contribute one vec4 each per block.
// Per-block max-abs is an 8-lane subgroup butterfly (in-subgroup since
// subgroup_min_size >= 8 is validated at load time); the 4-byte pack uses
// `packSnorm4x8` so there is no cross-lane gather and no `qv_sh` smem.

layout(constant_id = 0) const uint SUBGROUP_SIZE = 32;

layout(push_constant) uniform Params {
    uint k;             // input dim, multiple of 256
    uint input_offset;  // f16 elements
    uint weight_offset; // f16 elements (k weights, reused across tokens)
    uint d_offset;      // bytes (Q8_0 d-section, FP32 scales)
    uint qs_offset;     // bytes (Q8_0 qs-section, packed i8)
    float eps;
}
p;

layout(set = 0, binding = 0, std430) readonly buffer ActBuf { f16vec4 act[]; };
layout(set = 0, binding = 1, std430) readonly buffer WBuf { f16vec4 w[]; };
layout(set = 0, binding = 2, std430) buffer OutBuf { uint outbuf[]; };

const uint WG = 64u;
const uint BLOCK_SIZE = 32u;
const uint LANES_PER_BLOCK = BLOCK_SIZE / 4u;      // 8
const uint BLOCKS_PER_ITER = WG / LANES_PER_BLOCK; // 8
const uint NUM_SUBGROUPS = (WG + SUBGROUP_SIZE - 1u) / SUBGROUP_SIZE;

shared float sg_partial[NUM_SUBGROUPS];
shared float inv_h_sh;

#include "lib/subgroup_reduce_scalar.glsl"

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

void main() {
    uint token_idx = gl_WorkGroupID.x;
    uint tid = gl_LocalInvocationID.x;
    uint nb_q8 = p.k >> 5u; // / BLOCK_SIZE
    uint in_base = (p.input_offset + token_idx * p.k) >> 2u;
    uint w_base = p.weight_offset >> 2u;
    uint qs_token_word = (p.qs_offset + token_idx * p.k) >> 2u;
    uint d_token_word = (p.d_offset >> 2u) + token_idx * nb_q8;

    // ---- Phase 1: rms_norm sum-of-squares (vec4 per thread) ----
    float s = 0.0;
    uint k_v4 = p.k >> 2u;
    for (uint v = tid; v < k_v4; v += WG) {
        uint b = in_base + v;
        vec4 x = vec4(act[b]);
        s += dot(x, x);
    }
    float total_sq = wg_sum(s);
    if (tid == 0u) {
        inv_h_sh = inversesqrt(total_sq / float(p.k) + p.eps);
    }
    barrier();
    float inv_h = inv_h_sh;

    // ---- Phase 2: per-block normalize + Q8_0 quantize ----
    uint lane_in_block = tid & (LANES_PER_BLOCK - 1u); // 0..7
    uint block_within_iter = tid >> 3u;                // 0..7; / LANES_PER_BLOCK

    uint n_iters = nb_q8 >> 3u; // / BLOCKS_PER_ITER
    for (uint it = 0u; it < n_iters; it += 1u) {
        uint block_global = it * BLOCKS_PER_ITER + block_within_iter;
        uint elem_base = it * WG + tid;

        vec4 x = vec4(act[in_base + elem_base]);
        vec4 wv = vec4(w[w_base + elem_base]);
        vec4 v = x * inv_h * wv;

        vec4 av = abs(v);
        float m = max(max(av.x, av.y), max(av.z, av.w));
        m = max(m, subgroupShuffleXor(m, 1u));
        m = max(m, subgroupShuffleXor(m, 2u));
        m = max(m, subgroupShuffleXor(m, 4u));

        outbuf[qs_token_word + block_global * 8u + lane_in_block] = packSnorm4x8(v / max(m, 1e-30));
        if (lane_in_block == 0u) {
            outbuf[d_token_word + block_global] = floatBitsToUint(m / 127.0);
        }
    }
}
