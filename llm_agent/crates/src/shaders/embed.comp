#version 460

// Q1_0 / Q2_0 / Q8_0 row gather: dequant ONE row of the embedding matrix into f16.
// Reads the row index (token_id) from `sample[sample_offset + wg.x]`; this
// lets us chain steps on the GPU without a CPU round-trip — argmax of step
// N writes the input token for step N+1.
//
// dispatch: (m, 1, 1) — one workgroup per output row, 32 threads each.
// (Only nb = n_embd/128 threads do useful work; for n_embd=2560 that's 20.
// 32 keeps the workgroup small and SIMD-aligned.)

layout(push_constant) uniform Params {
    uint k; // n_embd
    uint d_offset;
    uint qs_offset;
    uint output_offset; // f16 elements
    uint sample_offset; // base index into sample[] for the input tokens
}
p;

layout(set = 0, binding = 0, std430) readonly buffer WBuf { uint weights[]; };
layout(set = 0, binding = 1, std430) buffer ActBuf { float16_t x[]; };
layout(set = 0, binding = 2, std430) readonly buffer SampleBuf { uint sample_in[]; };

#include "lib/bitfield.glsl"
#include "lib/q1_0_load.glsl"

uint load_half_bits(uint b_offset) {
    uint word = weights[b_offset >> 2u];
    return extract_bits(word, (b_offset & 2u) * 8u, 16u);
}

uint load_byte_at(uint b_offset) {
    uint word = weights[b_offset >> 2u];
    return extract_bits(word, (b_offset & 3u) * 8u, 8u);
}

layout(local_size_x = 32, local_size_y = 1, local_size_z = 1) in;

void main() {
    uint nb = p.k >> 7u;
    uint row = sample_in[p.sample_offset + gl_WorkGroupID.x];
    uint tid = gl_LocalInvocationID.x;
    if (tid >= nb)
        return;
    uint b = tid;
    uint d_byte_base = p.d_offset + (row * nb + b) * D_FP16_PER_BLOCK * 2u;
    uint qs_b = p.qs_offset + (row * nb + b) * QS_BYTES_PER_BLOCK;
    uint out_base = p.output_offset + gl_WorkGroupID.x * p.k + b * 128u;
    if (QUANT_FORMAT == 0u) {
        // Q1_0: 16 qs bytes/super-block, each byte = 8 sign bits.
        uint d_bits = load_half_bits(d_byte_base);
        [[unroll]]
        for (uint k = 0u; k < 16u; k += 1u) {
            uint qb = load_byte_at(qs_b + k);
            [[unroll]]
            for (uint bit = 0u; bit < 8u; bit += 1u) {
                // bit==1 → +d; bit==0 → -d (XOR the FP16 sign bit).
                uint signed_bits = d_bits ^ (extract_bits(~qb, bit, 1u) << 15u);
                x[out_base + k * 8u + bit] = uint16BitsToHalf(uint16_t(signed_bits));
            }
        }
    } else if (QUANT_FORMAT == 1u) {
        // Q2_0: 32 qs bytes/super-block, each byte = 4 codes of 2 bits;
        // weight = (q - 1) * d for q ∈ {0,1,2,3}.
        uint d_bits = load_half_bits(d_byte_base);
        [[unroll]]
        for (uint k = 0u; k < 32u; k += 1u) {
            uint qb = load_byte_at(qs_b + k);
            [[unroll]]
            for (uint c = 0u; c < 4u; c += 1u) {
                int q = int(extract_bits(qb, c * 2u, 2u));
                x[out_base + k * 4u + c] = float16_t(q - 1) * uint16BitsToHalf(uint16_t(d_bits));
            }
        }
    } else {
        // Q8_0: 128 qs bytes/super-block = 4 native 32-elem sub-blocks, each
        // with its own FP16 d. Weight = i8(qb) * d_sub.
        [[unroll]]
        for (uint s = 0u; s < 4u; s += 1u) {
            float16_t d_h = uint16BitsToHalf(uint16_t(load_half_bits(d_byte_base + s * 2u)));
            [[unroll]]
            for (uint k = 0u; k < 32u; k += 1u) {
                int q = int(load_byte_at(qs_b + s * 32u + k));
                // Sign-extend the i8: bit 7 maps the 0..255 byte to -128..127.
                q = (q ^ 0x80) - 0x80;
                x[out_base + s * 32u + k] = float16_t(q) * d_h;
            }
        }
    }
}
