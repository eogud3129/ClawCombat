#version 460

// RMSNorm: y = x * rsqrt(mean(x^2) + eps) * w
// SUBGROUP_SIZE (SpecId 0) is the per-pipeline effective subgroup size,
// patched at load time. NUM_SUBGROUPS is therefore constant after
// specialization, and the cross-subgroup merge below folds dead on hardware
// where the WG fits into a single subgroup.
//
// dispatch: (n_groups, 1, 1)

layout(constant_id = 0) const uint SUBGROUP_SIZE = 32;

const uint WG = 512;
const uint NUM_SUBGROUPS = (WG + SUBGROUP_SIZE - 1) / SUBGROUP_SIZE;

layout(push_constant) uniform Params {
    uint group_size;
    uint n_groups;
    uint input_offset;
    uint output_offset;
    uint weight_offset;
    float eps;
}
p;

layout(set = 0, binding = 0, std430) buffer ActBuf { float16_t act[]; };
layout(set = 0, binding = 1, std430) readonly buffer WBuf { float16_t w[]; };

shared float sg_partial[NUM_SUBGROUPS];

#include "lib/subgroup_reduce_scalar.glsl"

layout(local_size_x = 512, local_size_y = 1, local_size_z = 1) in;

void main() {
    uint gi = gl_WorkGroupID.x;
    if (gi >= p.n_groups)
        return;
    uint tid = gl_LocalInvocationID.x;
    uint n = p.group_size;
    uint in_base = p.input_offset + gi * n;
    uint out_base = p.output_offset + gi * n;

    float s = 0.0;
    for (uint i = tid; i < n; i += WG) {
        float v = float(act[in_base + i]);
        s += v * v;
    }

    float total = wg_sum(s);
    float16_t inv_h = float16_t(inversesqrt(total / float(n) + p.eps));
    for (uint i = tid; i < n; i += WG) {
        act[out_base + i] = act[in_base + i] * inv_h * w[p.weight_offset + i];
    }
}
