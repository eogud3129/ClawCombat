#version 460

// Multi-WG pass-1 of top-K reduction. Each workgroup processes a
// `[wg.x * n_per_wg, min((wg.x+1)*n_per_wg, n))` slice of the f16 logits and
// emits its own top-K_MAX (descending) into a scratch slot in `result`. The
// follow-up `topk_merge` dispatch consumes those `num_partials * K_MAX`
// candidates and produces the final top-K.
//
// Algorithm matches the original single-WG `topk_reduce`:
//   Phase 1:  per-thread top-K_MAX MIN-HEAP over the WG's slice.
//   Phase 2a: per-thread heap-sort to descending in place.
//   Phase 2b: parallel pairwise bitonic merge across all WG threads → final
//             top-K_MAX of this WG, descending, in `sh[0..K_MAX]`.
//   Phase 3:  write top-K_MAX values+indices to scratch slot
//             `result[partials_off + wg.x * 2*K_MAX ..]`.
//
// dispatch: (NUM_PARTIAL_WG, 1, 1)

layout(push_constant) uniform Params {
    uint n;            // total number of f16 logits
    uint in_offset;    // f16 element offset into `logits`; must be even
    uint partials_off; // u32 word offset into `result` for pass-1 scratch
    uint n_per_wg;     // # f16 logits assigned to each WG (last WG may overflow; clamped to n)
}
p;

layout(set = 0, binding = 0, std430) readonly buffer LogitsBuf { uint logits[]; };
layout(set = 0, binding = 1, std430) buffer ResultBuf { uint result[]; };

const uint WG = 128u;
const uint K_MAX = 32u;

// f16 LDS heap halves LDS use vs f32 (16 KiB → 8 KiB) and is lossless since
// logits enter at f16 precision.
shared float16_t sh_val[4096]; // WG * K_MAX
shared uint sh_idx[4096];

const float16_t NEG_INF_H = float16_t(-65504.0);

void sift_down(uint base) {
    uint i = 0u;
    // Heap depth is ceil(log2(K_MAX)) = 5; one extra iter for the early-out.
    [[unroll, min_iterations(1), max_iterations(6), dependency_length(1)]]
    while (true) {
        uint l = 2u * i + 1u;
        uint r = l + 1u;
        uint smallest = i;
        if (l < K_MAX && sh_val[base + l] < sh_val[base + smallest])
            smallest = l;
        if (r < K_MAX && sh_val[base + r] < sh_val[base + smallest])
            smallest = r;
        if (smallest == i)
            break;
        float16_t tv = sh_val[base + i];
        sh_val[base + i] = sh_val[base + smallest];
        sh_val[base + smallest] = tv;
        uint ti = sh_idx[base + i];
        sh_idx[base + i] = sh_idx[base + smallest];
        sh_idx[base + smallest] = ti;
        i = smallest;
    }
}

layout(local_size_x = 128, local_size_y = 1, local_size_z = 1) in;

void main() {
    uint tid = gl_LocalInvocationID.x;
    uint base = tid * K_MAX;

    // Slice for this WG. `in_offset` is f16-elements and even, so we iterate
    // in u32 words (= 2 f16) starting from `(in_offset + i_lo) >> 1u`.
    uint i_lo = gl_WorkGroupID.x * p.n_per_wg;
    uint i_hi = min(i_lo + p.n_per_wg, p.n);
    uint in_word_off = p.in_offset >> 1u;
    uint w_lo = i_lo >> 1u;        // i_lo is a multiple of 2 because n_per_wg is chosen even
    uint w_hi = (i_hi + 1u) >> 1u; // round up so we don't drop a trailing odd element

    // ---- Phase 1: build per-thread top-K min-heap.
    [[unroll]] for (uint i = 0u; i < K_MAX; i += 1u) {
        sh_val[base + i] = NEG_INF_H;
        sh_idx[base + i] = 0u;
    }
    for (uint w = w_lo + tid; w < w_hi; w += WG) {
        f16vec2 pair_f32 = uint16BitsToHalf(unpack16(logits[in_word_off + w]));
        uint i0 = w << 1u;
        uint i1 = i0 + 1u;
        float16_t v0 = pair_f32.x;
        if (i0 < i_hi && v0 > sh_val[base]) {
            sh_val[base] = v0;
            sh_idx[base] = i0;
            sift_down(base);
        }
        if (i1 < i_hi) {
            float16_t v1 = pair_f32.y;
            if (v1 > sh_val[base]) {
                sh_val[base] = v1;
                sh_idx[base] = i1;
                sift_down(base);
            }
        }
    }

    // ---- Phase 2a: heap-sort to descending. ----
    [[unroll, min_iterations(31), max_iterations(31), dependency_length(1)]]
    for (uint active_minus1 = K_MAX - 1u; active_minus1 > 0u; active_minus1 -= 1u) {
        uint last = base + active_minus1;
        float16_t tv = sh_val[base];
        sh_val[base] = sh_val[last];
        sh_val[last] = tv;
        uint ti = sh_idx[base];
        sh_idx[base] = sh_idx[last];
        sh_idx[last] = ti;
        uint i = 0u;
        [[unroll, min_iterations(1), max_iterations(6), dependency_length(1)]]
        while (true) {
            uint l = 2u * i + 1u;
            uint r = l + 1u;
            uint smallest = i;
            if (l < active_minus1 && sh_val[base + l] < sh_val[base + smallest])
                smallest = l;
            if (r < active_minus1 && sh_val[base + r] < sh_val[base + smallest])
                smallest = r;
            if (smallest == i)
                break;
            float16_t tv2 = sh_val[base + i];
            sh_val[base + i] = sh_val[base + smallest];
            sh_val[base + smallest] = tv2;
            uint ti2 = sh_idx[base + i];
            sh_idx[base + i] = sh_idx[base + smallest];
            sh_idx[base + smallest] = ti2;
            i = smallest;
        }
    }
    barrier();

    // ---- Phase 2b: parallel pairwise bitonic merge across all WG threads. ----
    uint s = WG / 2u;
    // s halves each iter, so iter count = log2(WG/2) = 6 for WG=128.
    [[unroll, min_iterations(6), max_iterations(6), dependency_length(1)]]
    while (s > 0u) {
        uint n_stage0 = s * K_MAX;
        for (uint k = tid; k < n_stage0; k += WG) {
            uint pair_id = k >> 5u; // / K_MAX
            uint i = k & (K_MAX - 1u);
            uint a_base = pair_id * K_MAX;
            uint b_base = (pair_id + s) * K_MAX;
            uint bi = K_MAX - 1u - i;
            float16_t av = sh_val[a_base + i];
            float16_t bv = sh_val[b_base + bi];
            if (bv > av) {
                sh_val[a_base + i] = bv;
                sh_idx[a_base + i] = sh_idx[b_base + bi];
            }
        }
        barrier();

        uint n_perstage = s * (K_MAX / 2u);
        uint stride = K_MAX / 2u;
        // stride halves each iter; K_MAX=32 so iter count = log2(K_MAX/2) = 4.
        [[unroll, min_iterations(4), max_iterations(4), dependency_length(1)]]
        while (stride > 0u) {
            for (uint k = tid; k < n_perstage; k += WG) {
                uint pair_id = k >> 4u; // / (K_MAX / 2u)
                uint local_k = k & ((K_MAX / 2u) - 1u);
                uint lo = ((local_k & ~(stride - 1u)) << 1u) | (local_k & (stride - 1u));
                uint hi = lo | stride;
                uint a_base = pair_id * K_MAX;
                float16_t vlo = sh_val[a_base + lo];
                float16_t vhi = sh_val[a_base + hi];
                if (vhi > vlo) {
                    uint ilo = sh_idx[a_base + lo];
                    sh_val[a_base + lo] = vhi;
                    sh_val[a_base + hi] = vlo;
                    sh_idx[a_base + lo] = sh_idx[a_base + hi];
                    sh_idx[a_base + hi] = ilo;
                }
            }
            barrier();
            stride = stride >> 1u;
        }

        s = s >> 1u;
    }

    // ---- Phase 3: write top-K_MAX of this WG to scratch ----
    // Slot layout: [K_MAX f32 values | K_MAX u32 indices], starting at
    // result[partials_off + wg.x * 2*K_MAX].
    uint slot_base = p.partials_off + gl_WorkGroupID.x * (2u * K_MAX);
    if (tid < K_MAX) {
        // Inter-pass storage stays f32 (untouched layout); widen the f16 LDS
        // value for free at the boundary.
        result[slot_base + tid] = floatBitsToUint(float(sh_val[tid]));
        result[slot_base + K_MAX + tid] = sh_idx[tid];
    }
}
