#version 460

// dotPacked4x8EXT matmul: Q1_0/Q2_0/Q8_0 weights × Q8_0 activations -> f16.
//
// 64×64 tile, 256 threads, each thread = 4×4 = 16 cells. Weights are decoded
// cooperatively into `w_quads_lds[s*512 + i*64 + n_col]` at load time (Q1_0
// expands 8 nibbles/qword via expand_4_bits, Q2_0 expands 4 bytes from each of
// 2 qwords via expand_8_bits, Q8_0 stores the raw qwords). The inner
// accumulation then streams one `i` worth of weights (`w_i[TN]`, 4 regs) from
// LDS at a time and fans it out across all TM rows — versus the older
// per-thread `w[TN][8]` (32 regs) cache. Net register save ~25/thread lifts
// occupancy on register-bound GPUs (NVIDIA Blackwell).
//
// Per-sub-block weight scale: Q1_0/Q2_0 broadcast one FP16 d across all 4
// sub-blocks of a 128-elem super-block; Q8_0 carries 4 distinct FP16 d.
// Both are cached as 4 × 64 = 256 floats in `w_d_lds`, indexed `[s*64 + n]`.

layout(push_constant) uniform Params {
    uint k;
    uint n;
    uint m;
    uint w_d_offset;
    uint w_qs_offset;
    uint a_d_offset;
    uint a_qs_offset;
    uint out_offset;
    uint accumulate;
}
p;

layout(set = 0, binding = 0, std430) readonly buffer WBuf { uint weights[]; };
layout(set = 0, binding = 1, std430) readonly buffer ABuf { uint acts[]; };
layout(set = 0, binding = 2, std430) buffer YBuf { uint y[]; };

#include "lib/bitfield.glsl"
#include "lib/q1_0_load.glsl"

const uint WG_N = 16u;
const uint WG_M = 16u;
const uint WG = 256u;
const uint TN = 4u;
const uint TM = 4u;
const uint TILE_N = 64u;
const uint TILE_M = 64u;

shared float w_d_lds[64 * D_FP16_PER_BLOCK]; // 1 (Q1_0/Q2_0) or 4 (Q8_0) scales × 64 cols
shared uint w_quads_lds[2048];               // [s*512 + i*64 + n_col] decoded packed-i8 weight quads
shared float a_d_lds[256];
shared uint a_qs_lds[2048];

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

void main() {
    uint n_base = gl_WorkGroupID.x * TILE_N;
    uint m_base = gl_WorkGroupID.y * TILE_M;
    uint nb_q1 = p.k >> 7u;
    uint nb_q8 = p.k >> 5u;
    uint tid = gl_LocalInvocationIndex;

    uint lx = tid & (WG_N - 1u);
    uint ly = tid >> 4u; // / WG_N

    float acc[TM * TN];
    [[unroll]] for (uint i = 0u; i < TM * TN; i += 1u)
        acc[i] = 0.0;

    // Bonsai's matmul callers guarantee tile alignment / activation buffer
    // padding; OOB loads stay in LDS slots only their owner consults, and
    // final writes are gated by m_idx < p.m.
    //
    // Loop hints: every Bonsai matmul caller picks K as a multiple of 512
    // (n_embd=2560/3072, q_dim=2048, ffn=9728), so nb_q1 = K/128 is always a
    // multiple of 4 and at least 16 (smallest case is Wo on 4B). The acc[]
    // update is a length-1 loop carry (associative reduction).
    [[unroll, min_iterations(16), iteration_multiple(4), dependency_length(1)]]
    for (uint b = 0u; b < nb_q1; b += 1u) {
        // ---- Cooperative loads ----
        // Q1_0/Q2_0: 1 FP16 scale per super-block × 64 cols = 64 loads.
        // Q8_0: 4 scales per super-block × 64 cols = 256 loads (1 per thread).
        if (QUANT_FORMAT == 3u) {
            // 4 sub-block scales × 64 cols = 256 FP16's. Pair adjacent
            // sub-blocks (s, s+1) per thread — 128 threads, one f16vec2 each,
            // writing two LDS slots.
            if (tid < 128u) {
                uint s_pair = tid >> 6u; // 0 or 1
                uint n_local = tid & 63u;
                uint n_idx = n_base + n_local;
                uint s = s_pair * 2u;
                vec2 ds = load_2xf16_at(p.w_d_offset + (n_idx * nb_q1 * 4u + b * 4u + s) * 2u);
                w_d_lds[s * 64u + n_local] = ds.x;
                w_d_lds[(s + 1u) * 64u + n_local] = ds.y;
            }
        } else {
            if (tid < 64u) {
                uint n_idx = n_base + tid;
                w_d_lds[tid] = load_f16_at(p.w_d_offset + (n_idx * nb_q1 + b) * 2u);
            }
        }
        // Decode weights cooperatively into `w_quads_lds[s*512 + i*64 + n_col]`.
        // Q1_0: 256 threads × 1 qword → 8 decoded quads each.
        // Q2_0: 256 threads × 2 qwords → 4 decoded quads per qword.
        // Q8_0: 256 threads × 8 qwords (raw, no decode), kept by existing pass loop.
        if (QUANT_FORMAT == 0u) {
            uint s = tid >> 6u;
            uint n_local = tid & 63u;
            uint n_idx = n_base + n_local;
            uint off = p.w_qs_offset + n_idx * (nb_q1 * QS_BYTES_PER_BLOCK) + b * QS_BYTES_PER_BLOCK + s * 4u;
            uint bw = weights[off >> 2u];
            [[unroll]] for (uint i = 0u; i < 8u; i += 1u) {
                uint bits = extract_bits(bw, i * 4u, 4u);
                w_quads_lds[s * 512u + i * 64u + n_local] = expand_4_bits(bits);
            }
        } else if (QUANT_FORMAT == 1u) {
            uint s = tid >> 6u;
            uint n_local = tid & 63u;
            uint n_idx = n_base + n_local;
            [[unroll]] for (uint wq = 0u; wq < 2u; wq += 1u) {
                uint off =
                    p.w_qs_offset + n_idx * (nb_q1 * QS_BYTES_PER_BLOCK) + b * QS_BYTES_PER_BLOCK + (s * 2u + wq) * 4u;
                uint qword = weights[off >> 2u];
                [[unroll]] for (uint i = 0u; i < 4u; i += 1u) {
                    uint byte = extract_bits(qword, i * 8u, 8u);
                    w_quads_lds[s * 512u + (wq * 4u + i) * 64u + n_local] = expand_8_bits(byte);
                }
            }
        } else {
            // Q8_0: 8 passes of 256 raw qwords. Flat qword index s∈[0,32) maps
            // directly to (sub_s*8 + i), matching w_quads_lds[(s*8+i)*64+n_col].
            [[unroll]] for (uint pass = 0u; pass < 8u; pass += 1u) {
                uint n_local = tid >> 2u;
                uint s = (tid & 3u) + pass * 4u;
                uint n_idx = n_base + n_local;
                uint off = p.w_qs_offset + n_idx * (nb_q1 * QS_BYTES_PER_BLOCK) + b * QS_BYTES_PER_BLOCK + s * 4u;
                w_quads_lds[s * 64u + n_local] = weights[off >> 2u];
            }
        }
        {
            uint s = tid >> 6u;
            uint m_local = tid & 63u;
            uint m_idx = m_base + m_local;
            uint a_block = b * 4u + s;
            uint off = p.a_d_offset + (m_idx * nb_q8 + a_block) * 4u;
            a_d_lds[s * 64u + m_local] = uintBitsToFloat(acts[off >> 2u]);
        }
        [[unroll]] for (uint li = 0u; li < 8u; li += 1u) {
            uint idx = li * WG + tid;
            uint m_local = idx >> 5u;
            uint su = idx & 31u;
            uint m_idx = m_base + m_local;
            uint off = p.a_qs_offset + m_idx * p.k + b * 128u + su * 4u;
            a_qs_lds[m_local * 32u + su] = acts[off >> 2u];
        }
        barrier();

        // 4 Q8_0 sub-blocks per 128-elem super-block. Inner loop streams one
        // `i` worth of weight quads from LDS at a time (4 regs) and fans it
        // out across all TM rows — avoids materializing the full `w[TN][8]`
        // (32 regs) per thread.
        [[unroll]] for (uint s = 0u; s < 4u; s += 1u) {
            uint d_slot = (QUANT_FORMAT == 3u) ? (s * 64u + lx * TN) : (lx * TN);

            int sumi[TM * TN];
            [[unroll]] for (uint t = 0u; t < TM * TN; t += 1u)
                sumi[t] = 0;

            [[unroll]] for (uint i = 0u; i < 8u; i += 1u) {
                uint w_i[TN];
                [[unroll]] for (uint tn = 0u; tn < TN; tn += 1u) {
                    w_i[tn] = w_quads_lds[s * 512u + i * 64u + lx * TN + tn];
                }
                uint a_tm[TM];
                [[unroll]] for (uint tm = 0u; tm < TM; tm += 1u) {
                    a_tm[tm] = a_qs_lds[(ly * TM + tm) * 32u + s * 8u + i];
                }
                [[unroll]] for (uint tm = 0u; tm < TM; tm += 1u) {
                    [[unroll]] for (uint tn = 0u; tn < TN; tn += 1u) {
                        sumi[tm * TN + tn] += dotPacked4x8EXT(int(w_i[tn]), int(a_tm[tm]));
                    }
                }
            }

            float wd[TN];
            [[unroll]] for (uint tn = 0u; tn < TN; tn += 1u) { wd[tn] = w_d_lds[d_slot + tn]; }
            [[unroll]] for (uint tm = 0u; tm < TM; tm += 1u) {
                float a_d = a_d_lds[s * 64u + ly * TM + tm];
                [[unroll]] for (uint tn = 0u; tn < TN; tn += 1u) {
                    acc[tm * TN + tn] += a_d * wd[tn] * float(sumi[tm * TN + tn]);
                }
            }
        }
        barrier();
    }

    [[unroll]] for (uint tm = 0u; tm < TM; tm += 1u) {
        uint m_idx = m_base + ly * TM + tm;
        if (m_idx >= p.m)
            break;
        [[unroll]] for (uint tn = 0u; tn < TN; tn += 2) {
            uint n_idx = n_base + lx * TN + tn;
            if (n_idx >= p.n)
                break;
            uint yi = (p.out_offset + m_idx * p.n + n_idx) >> 1u;
            vec2 val = vec2(acc[tm * TN + tn], acc[tm * TN + tn + 1]);
            y[yi] = packHalf2x16(p.accumulate != 0u ? unpackHalf2x16(y[yi]) + val : val);
        }
    }
}
