#version 460

// Fused per-layer Q-side pre-attention pipeline:
//   rms_norm(Q head) -> *w_q_norm -> NEOX-RoPE -> write back to act.q (f16,
//   in place).
// Replaces a 2-dispatch sequence (rms_norm Q, rope Q) with 1.
//
// Workgroup = head_dim (128). One workgroup per (head, token) processes one
// Q head. Dispatch (n_head, m_tokens, 1).

layout(constant_id = 0) const uint SUBGROUP_SIZE = 32;

layout(push_constant) uniform Params {
    uint q_off;        // f16 element offset of Q in act (q region base)
    uint w_q_norm_off; // f16 element offset of w_q_norm[0..head_dim] in w_norms
    uint rope_offset;  // f16 element base offset into rope_cs (typically 0)
    uint pos_base;     // first absolute RoPE position
    uint q_dim;        // = n_head * head_dim
    float eps;
}
p;

layout(set = 0, binding = 0, std430) buffer ActBuf { float16_t act[]; };
layout(set = 0, binding = 1, std430) readonly buffer WBuf { float16_t w_norms[]; };
layout(set = 0, binding = 2, std430) readonly buffer RopeBuf { float16_t rope_cs[]; };

const uint HEAD_DIM = 128u;
const uint HALF_DIM = 64u;
const uint WG = 128u;
const uint NUM_SUBGROUPS = (WG + SUBGROUP_SIZE - 1u) / SUBGROUP_SIZE;

// rope_in_sh holds normed-and-weighted Q so RoPE can fetch each thread's pair
// partner across the head-half boundary. After RoPE the rotated value lives in
// a register; rope_in_sh is dead.
shared float16_t rope_in_sh[HEAD_DIM];
// Cross-subgroup merge slot for the RMS reduction.
shared float sg_partial[NUM_SUBGROUPS];

#include "lib/subgroup_reduce_scalar.glsl"

layout(local_size_x = 128, local_size_y = 1, local_size_z = 1) in;

void main() {
    uint head = gl_WorkGroupID.x;
    uint tok = gl_WorkGroupID.y;
    uint tid = gl_LocalInvocationID.x;

    uint q_token_off = tok * p.q_dim + head * HEAD_DIM;
    uint q_idx = p.q_off + q_token_off + tid;
    float q_raw = float(act[q_idx]);

    float inv_h = inversesqrt(wg_sum(q_raw * q_raw) / float(HEAD_DIM) + p.eps);

    // ---- norm * weight, stash to shmem so RoPE can swap pairs ----
    rope_in_sh[tid] = float16_t(q_raw * inv_h) * w_norms[p.w_q_norm_off + tid];
    barrier();

    uint pos_abs = p.pos_base + tok;
    uint cs_base = p.rope_offset + pos_abs * HEAD_DIM;

    // NEOX RoPE: pair-swap across the head-half boundary. Both halves compute
    // self*c ± partner*s; only the sign on the s-term flips (− for first half,
    // + for second).
    uint base = tid & (HALF_DIM - 1u);
    float16_t c = rope_cs[cs_base + base * 2u];
    float16_t s = rope_cs[cs_base + base * 2u + 1u];
    float16_t self_v = rope_in_sh[tid];
    float16_t partner = rope_in_sh[tid ^ HALF_DIM];
    uint16_t sign = uint16_t(((tid - HALF_DIM) >> 16u) & 0x8000u);
    act[q_idx] = self_v * c + uint16BitsToHalf(halfBitsToUint16(partner * s) ^ sign);
}
