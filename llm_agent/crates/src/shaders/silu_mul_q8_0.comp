#version 460

// Fused: y = silu(gate) * up  →  Q8_0 quantize  →  write to act_q8.
//
// Replaces the prefill-path pair `silu_mul` (writes act.ffn_in) +
// `quantize_q8_0` (reads act.ffn_in, writes act_q8). The fused version keeps
// each silu*up product in registers, computes per-32-block max-abs, and
// writes Q8_0 directly.
//
// Output layout (matches `quantize_q8_0`):
//   d (f32):  outbuf[d_offset/4 + token*nb_q8 + b]
//   qs (i8):  outbuf[qs_offset/4 + (token*k + b*32)/4 + sub] for sub in 0..8
//
// dispatch: (m, 1, 1) — one workgroup per token. Caller must guarantee
// `(k/32) % 8 == 0`, which holds for k = n_ff = 9728 on Bonsai 4B/8B.
//
// Threading: WG=64, one thread per **vec4** of input. Per iteration we cover
// 256 elements = 8 Q8_0 blocks, with 8 threads contributing one vec4 each per
// block. Per-block max-abs is an 8-lane subgroup butterfly (always in-sg,
// since subgroup_min_size >= 8 is validated at load time). The 4-byte pack
// is `packSnorm4x8`, so there is no cross-lane gather and no `qv_sh` smem.

layout(push_constant) uniform Params {
    uint k;           // n_ff, multiple of 256
    uint gate_offset; // f16 elements
    uint up_offset;   // f16 elements
    uint d_offset;    // bytes (Q8_0 d-section, FP32 scales)
    uint qs_offset;   // bytes (Q8_0 qs-section, packed i8)
}
p;

layout(set = 0, binding = 0, std430) readonly buffer ActBuf { f16vec4 act[]; };
layout(set = 0, binding = 1, std430) buffer OutBuf { uint outbuf[]; };

const uint WG = 64u;
const uint BLOCK_SIZE = 32u;
const uint LANES_PER_BLOCK = BLOCK_SIZE / 4u;      // 8
const uint BLOCKS_PER_ITER = WG / LANES_PER_BLOCK; // 8

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

void main() {
    uint token_idx = gl_WorkGroupID.x;
    uint tid = gl_LocalInvocationID.x;
    uint nb_q8 = p.k >> 5u; // / BLOCK_SIZE
    uint g_base = (p.gate_offset + token_idx * p.k) >> 2u;
    uint u_base = (p.up_offset + token_idx * p.k) >> 2u;
    uint qs_token_word = (p.qs_offset + token_idx * p.k) >> 2u;
    uint d_token_word = (p.d_offset >> 2u) + token_idx * nb_q8;

    uint lane_in_block = tid & (LANES_PER_BLOCK - 1u); // 0..7
    uint block_within_iter = tid >> 3u;                // 0..7; / LANES_PER_BLOCK

    uint n_iters = nb_q8 >> 3u; // / BLOCKS_PER_ITER
    for (uint it = 0u; it < n_iters; it += 1u) {
        uint block_global = it * BLOCKS_PER_ITER + block_within_iter;
        uint elem_base = it * WG + tid;

        vec4 g = vec4(act[g_base + elem_base]);
        vec4 u = vec4(act[u_base + elem_base]);
        vec4 s = g / (vec4(1.0) + exp(-g));
        vec4 v = s * u;

        vec4 av = abs(v);
        float m = max(max(av.x, av.y), max(av.z, av.w));
        // 8-lane butterfly (xor 1/2/4) — masks all <= 4 stay in-subgroup
        // because subgroup_min_size >= 8 is validated at Model::load.
        m = max(m, subgroupShuffleXor(m, 1u));
        m = max(m, subgroupShuffleXor(m, 2u));
        m = max(m, subgroupShuffleXor(m, 4u));

        outbuf[qs_token_word + block_global * 8u + lane_in_block] = packSnorm4x8(v / max(m, 1e-30));
        if (lane_in_block == 0u) {
            outbuf[d_token_word + block_global] = floatBitsToUint(m / 127.0);
        }
    }
}
