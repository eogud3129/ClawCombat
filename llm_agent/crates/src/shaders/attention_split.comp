#version 460

// Split-K + GQA-batched attention chunk pass for the matvec (m_tokens=1) path.
//
// dispatch: (n_kv_head, n_chunks_active, 1).
//
// Each workgroup handles one (kv_group, chunk) pair, scanning the cache slice
// [chunk * CHUNK_SIZE, min((chunk+1) * CHUNK_SIZE, pos)) and producing partial
// (m, l, o) state for all Q_PER_GROUP=4 Q heads that share this KV head. The
// four Q·K dots are computed in parallel via vec4 packing and reduced through
// wg_sum_v4 — a subgroupAdd that takes a single instruction when
// num_subgroups == 1 (e.g. RDNA wave64 with WG=64) and runs a runtime
// cross-subgroup merge otherwise.

layout(constant_id = 0) const uint SUBGROUP_SIZE = 32;

layout(push_constant) uniform Params {
    uint head_dim;
    uint n_head;
    uint n_kv_head;
    uint pos;
    uint kv_stride;
    uint q_offset;
    uint k_d_word_offset;
    uint k_qs_byte_offset;
    uint v_d_word_offset;
    uint v_qs_byte_offset;
    uint n_chunks_active;
    float scale;
}
p;

layout(set = 0, binding = 0, std430) readonly buffer ActBuf { float16_t act[]; };
layout(set = 0, binding = 1, std430) readonly buffer KCache { uint k_cache[]; };
layout(set = 0, binding = 2, std430) readonly buffer VCache { uint v_cache[]; };
layout(set = 0, binding = 3, std430) buffer Partials { float partials[]; };

// Apple sweep: WG=32 (1 simdgroup) wins ~5% on tg over WG=64 — `wg_sum_v4`
// becomes a no-op (NUM_SUBGROUPS=1 → simd_sum already covers the whole WG)
// and the smem-staged cross-SG combine drops out. ELEMS_PER_THREAD doubles
// to keep head_dim=128 covered.
#ifndef METAL_BACKEND
const uint WG = 64u;
const uint ELEMS_PER_THREAD = 2u; // head_dim (128) / WG (64)
#else
const uint WG = 32u;
const uint ELEMS_PER_THREAD = 4u; // head_dim (128) / WG (32)
#endif
const uint NUM_SUBGROUPS = (WG + SUBGROUP_SIZE - 1u) / SUBGROUP_SIZE;
const uint Q_PER_GROUP = 4u;
const uint CHUNK_SIZE = 8u;
const uint PARTIAL_STRIDE = 130u; // head_dim + 2

shared vec4 sg_partial4[NUM_SUBGROUPS];

#include "lib/bitfield.glsl"
#include "lib/kv_cache_load.glsl"
#include "lib/subgroup_reduce_v4.glsl"

#ifndef METAL_BACKEND
layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;
#else
layout(local_size_x = 32, local_size_y = 1, local_size_z = 1) in;
#endif

void main() {
    uint g = gl_WorkGroupID.x;
    uint chunk = gl_WorkGroupID.y;
    if (g >= p.n_kv_head || chunk >= p.n_chunks_active)
        return;
    uint tid = gl_LocalInvocationID.x;
    uint hd = p.head_dim;
    uint chunk_start = chunk * CHUNK_SIZE;
    uint chunk_end = min(chunk_start + CHUNK_SIZE, p.pos);
    uint g_off = g * hd;

    uvec4 q_base = (uvec4(0u, 1u, 2u, 3u) + g * Q_PER_GROUP) * hd + p.q_offset;

    vec4 o[ELEMS_PER_THREAD];
    [[unroll]] for (uint i = 0u; i < ELEMS_PER_THREAD; i += 1u) { o[i] = vec4(0.0); }
    vec4 m = vec4(-1e30);
    vec4 l = vec4(0.0);

    // t loop: at most CHUNK_SIZE=8 iterations (chunk_end - chunk_start <= 8).
    // m/l/o[] are length-1 loop-carried.
    [[unroll, min_iterations(1), max_iterations(8), dependency_length(1)]]
    for (uint t = chunk_start; t < chunk_end; t += 1u) {
        vec4 local_v = vec4(0.0);
        // d loop: head_dim=128 elements with WG=64 stride → exactly 2 iters
        // (= ELEMS_PER_THREAD). Pure reduction into local_v.
        [[unroll, min_iterations(2), max_iterations(2), dependency_length(1)]]
        for (uint d = tid; d < hd; d += WG) {
            float k = load_k(t, g_off + d);
            uvec4 q_idx = q_base + d;
            local_v += k * vec4(f16vec4(act[q_idx.x], act[q_idx.y], act[q_idx.z], act[q_idx.w]));
        }
        vec4 dots = wg_sum_v4(local_v);
        vec4 scores = dots * p.scale;

        vec4 m_new = max(m, scores);
        vec4 correction = exp(m - m_new);
        vec4 weight = exp(scores - m_new);
        l = l * correction + weight;
        m = m_new;

        [[unroll]] for (uint i = 0u; i < ELEMS_PER_THREAD; i += 1u) {
            uint d = tid + i * WG;
            float v = load_v(t, g_off + d);
            o[i] = o[i] * correction + weight * v;
        }
    }

    uint stride_h = p.n_chunks_active * PARTIAL_STRIDE;
    [[unroll]] for (uint i = 0u; i < ELEMS_PER_THREAD; i += 1u) {
        uint d = tid + i * WG;
        [[unroll]] for (uint j = 0u; j < 4u; j += 1u) {
            uint h = g * Q_PER_GROUP + j;
            uint base = h * stride_h + chunk * PARTIAL_STRIDE;
            partials[base + d] = o[i][j];
        }
    }
    if (tid == 0u) {
        [[unroll]] for (uint j = 0u; j < 4u; j += 1u) {
            uint h = g * Q_PER_GROUP + j;
            uint base = h * stride_h + chunk * PARTIAL_STRIDE;
            partials[base + hd] = m[j];
            partials[base + hd + 1u] = l[j];
        }
    }
}
